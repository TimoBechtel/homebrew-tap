#!/usr/bin/env ruby
# frozen_string_literal: true

require "digest"
require "json"
require "net/http"
require "open-uri"
require "uri"

REPO = "TimoBechtel/hey-comma"
FORMULA_PATH = File.expand_path("../Formula/hey-comma.rb", __dir__)
ASSET_NAMES = [
  "hey-darwin-arm64",
  "hey-darwin-x64",
  "hey-linux-x64",
].freeze

def github_json(path)
  uri = URI("https://api.github.com/#{path}")
  request = Net::HTTP::Get.new(uri)
  request["Accept"] = "application/vnd.github+json"
  request["X-GitHub-Api-Version"] = "2022-11-28"

  token = ENV["GITHUB_TOKEN"] || ENV["GH_TOKEN"]
  request["Authorization"] = "Bearer #{token}" if token && !token.empty?

  response = Net::HTTP.start(uri.hostname, uri.port, use_ssl: true) do |http|
    http.request(request)
  end

  abort "GitHub API request failed: #{response.code} #{response.message}" unless response.is_a?(Net::HTTPSuccess)

  JSON.parse(response.body)
end

def asset_sha256(asset)
  digest = asset["digest"]
  return digest.delete_prefix("sha256:") if digest&.start_with?("sha256:")

  token = ENV["GITHUB_TOKEN"] || ENV["GH_TOKEN"]
  headers = token && !token.empty? ? { "Authorization" => "Bearer #{token}" } : {}
  Digest::SHA256.hexdigest(URI.open(asset.fetch("browser_download_url"), headers, &:read))
end

release = github_json("repos/#{REPO}/releases/latest")
tag_name = release.fetch("tag_name")
abort "Latest release tag must start with v: #{tag_name}" unless tag_name.start_with?("v")

version = tag_name.delete_prefix("v")
assets = release.fetch("assets")
sha256_by_asset = ASSET_NAMES.to_h do |asset_name|
  asset = assets.find { |candidate| candidate.fetch("name") == asset_name }
  abort "Release #{tag_name} does not include #{asset_name}" unless asset

  [asset_name, asset_sha256(asset)]
end

formula = File.read(FORMULA_PATH)
abort "Formula is missing a version stanza" unless formula.match?(/^  version ".*"$/)

updated_formula = formula.sub(/^  version ".*"$/, %(  version "#{version}"))

sha256_by_asset.each do |asset_name, sha256|
  asset_pattern = Regexp.escape(asset_name)
  stanza_pattern = /^(\s+)(url ".*\/#{asset_pattern}")\n\1sha256 ".*"$/
  abort "Formula is missing a #{asset_name} asset stanza" unless updated_formula.match?(stanza_pattern)

  updated_formula = updated_formula.sub(stanza_pattern) do
    "#{$1}#{$2}\n#{$1}sha256 \"#{sha256}\""
  end
end

if updated_formula == formula
  puts "hey-comma is already at #{version}"
else
  File.write(FORMULA_PATH, updated_formula)
  puts "Updated hey-comma to #{version}"
end
